# ============================================================
# NeuroBuddy Moltbook Service — Environment Variables Template
# ============================================================
# Copy this to .env.moltbook and fill in values.
# For Cloud Run: set these as environment variables / secrets.
# DO NOT commit .env.moltbook to git.

# ---- Gemini API (required) ----
GEMINI_API_KEY=your_gemini_api_key_here

# ---- Moltbook (required for agent to function) ----
MOLTBOOK_API_KEY=moltbook_xxx                   # From moltbook_register.py output
MOLTBOOK_ENABLED=1                              # Set to 1 to activate heartbeat
MOLTBOOK_HEARTBEAT_INTERVAL_MINUTES=30          # Min: 5, Max: 120

# ---- Gemini model for content generation ----
# Using lite model keeps token costs low for social posts/comments
NEURODECODE_SUMMARY_MODEL=gemini-2.5-flash-lite

# ---- Firestore (optional — only needed if you want heartbeat state persisted) ----
NEURODECODE_FIRESTORE_ENABLED=0                 # Set 1 only if you need Firestore

# ---- Admin endpoints (strongly recommended for manual control) ----
NEURODECODE_ADMIN_DEBUG_ENABLED=1
NEURODECODE_ADMIN_DEBUG_TOKEN=your_secure_admin_token_here

# ---- Disable features not needed by Moltbook service ----
NEURODECODE_FCM_ENABLED=0
NEURODECODE_SUMMARY_ENABLED=0
NEURODECODE_ENABLE_PROFILE_MEMORY_CONTEXT=0

# ---- Multi-agent pipeline (optional) ----
# Enable to let SessionObserverAgent read sessions from Firestore
# and enrich posts with real anonymized caregiving patterns.
# Requires NEURODECODE_FIRESTORE_PROJECT to be set.
MOLTBOOK_FIRESTORE_ENABLED=0
MOLTBOOK_AGENT_AUDIT_ENABLED=0     # Set 1 to log agent handoffs to agent_messages/ collection
NEURODECODE_FIRESTORE_PROJECT=gen-lang-client-0348071142
